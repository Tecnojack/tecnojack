rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // ── Media (subidas desde media-admin, consumidas por el portfolio público) ──
    match /media/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /mediaFolders/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ── CMS (servicios, paquetes, categorías, páginas, secciones) ──
    // Lectura pública; escritura solo para admins autenticados.
    match /services/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /packages/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /categories/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /pages/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /sections/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /pageSnapshots/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /sectionsData/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ── Clientes públicos del portfolio ──
    // Se leen desde /portfolio (bodas, quinces, grados).
    match /clients/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ── Leads de solicitudes de servicio ──
    // Crear público desde frontend. Lectura/actualización para panel autenticado.
    match /service_requests/{docId} {
      allow create: if true;
      allow read, update: if isSignedIn();
      allow delete: if false;
    }

    // ── Bodas / Invitados (lectura pública) ──
    match /weddings/{weddingId} {
      allow read: if true;
      allow write: if false;

      match /guests/{guestId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ── Usuarios admin (solo lectura autenticada, sin escritura desde cliente) ──
    match /adminUsers/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Bloquear todo lo que no está explícitamente listado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
