  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "firebase:seed:cms": "tsx --tsconfig tsconfig.scripts.json scripts/firebase-seed-cms.ts",
