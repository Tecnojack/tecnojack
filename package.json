    "firebase:seed:weddings:dry-run": "tsx --tsconfig tsconfig.scripts.json scripts/firebase-seed-weddings.ts --dry-run",
    "firebase:seed:weddings:reset": "tsx --tsconfig tsconfig.scripts.json scripts/firebase-seed-weddings.ts --reset",
    "firebase:seed:clients": "tsx --tsconfig tsconfig.scripts.json scripts/firebase-seed-clients.ts",
    "firebase:seed:clients:dry-run": "tsx --tsconfig tsconfig.scripts.json scripts/firebase-seed-clients.ts --dry-run"
